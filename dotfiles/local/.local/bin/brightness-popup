#!/usr/bin/env bash
set -euo pipefail

current="$(brightnessctl -m | awk -F, '{gsub(/%/, "", $4); print $4; exit}')"
current="${current:-50}"

value="$(
  yad \
    --scale \
    --title="Brightness" \
    --text="Display brightness" \
    --min-value=1 \
    --max-value=100 \
    --step=1 \
    --value="$current" \
    --width=360 \
    --button="Apply:0" \
    --button="Cancel:1"
)"

case "$value" in
  '')
    exit 0
    ;;
  *)
    value="${value%.*}"
    case "$value" in
      ''|*[!0-9]*)
        exit 0
        ;;
    esac
    brightnessctl set "${value}%"
    ;;
esac
