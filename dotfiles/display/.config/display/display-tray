#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/display-profiles"
ACTIVE_FILE="$STATE_DIR/profile"

notify() {
    notify-send "Displays" "$1" >/dev/null 2>&1 || true
}

set_niri_output() {
    local output="$1"
    shift

    if ! niri msg output "$output" "$@" >/dev/null 2>&1; then
        notify "Could not configure $output"
        return 1
    fi
}

set_active() {
    install -d "$STATE_DIR"
    printf '%s\n' "$1" > "$ACTIVE_FILE"
}

vertical_profile() {
    set_niri_output HDMI-A-1 on
    set_niri_output eDP-1 on
    set_niri_output HDMI-A-1 mode 2560x1440@143.912
    set_niri_output HDMI-A-1 scale 1
    set_niri_output HDMI-A-1 transform normal
    set_niri_output HDMI-A-1 position set 0 0
    set_niri_output eDP-1 mode 2560x1600@240
    set_niri_output eDP-1 scale 1.25
    set_niri_output eDP-1 transform normal
    set_niri_output eDP-1 position set 255 1440
    set_active vertical
    notify "Profile active: Vertical"
}

horizontal_profile() {
    set_niri_output HDMI-A-1 on
    set_niri_output eDP-1 on
    set_niri_output HDMI-A-1 mode 2560x1440@143.912
    set_niri_output HDMI-A-1 scale 1
    set_niri_output HDMI-A-1 transform normal
    set_niri_output HDMI-A-1 position set 0 0
    set_niri_output eDP-1 mode 2560x1600@240
    set_niri_output eDP-1 scale 1.25
    set_niri_output eDP-1 transform normal
    set_niri_output eDP-1 position set 2560 160
    set_active horizontal
    notify "Profile active: Horizontal"
}

laptop_profile() {
    set_niri_output eDP-1 on
    set_niri_output eDP-1 mode 2560x1600@240
    set_niri_output eDP-1 scale 1.25
    set_niri_output eDP-1 transform normal
    set_niri_output eDP-1 position set 0 0
    set_niri_output HDMI-A-1 off || true
    set_active laptop
    notify "Profile active: Laptop"
}

external_profile() {
    set_niri_output HDMI-A-1 on
    set_niri_output HDMI-A-1 mode 2560x1440@143.912
    set_niri_output HDMI-A-1 scale 1
    set_niri_output HDMI-A-1 transform normal
    set_niri_output HDMI-A-1 position set 0 0
    set_niri_output eDP-1 off || true
    set_active external
    notify "Profile active: External"
}

auto_profile() {
    niri msg output HDMI-A-1 on >/dev/null 2>&1 || true
    niri msg output eDP-1 on >/dev/null 2>&1 || true
    niri msg output HDMI-A-1 mode auto >/dev/null 2>&1 || true
    niri msg output eDP-1 mode auto >/dev/null 2>&1 || true
    niri msg output HDMI-A-1 scale auto >/dev/null 2>&1 || true
    niri msg output eDP-1 scale auto >/dev/null 2>&1 || true
    niri msg output HDMI-A-1 position auto >/dev/null 2>&1 || true
    niri msg output eDP-1 position auto >/dev/null 2>&1 || true
    set_active auto
    notify "Profile active: Auto"
}

open_wdisplays() {
    wdisplays >/dev/null 2>&1 &
}

open_menu() {
    local choice
    choice="$(
        yad --list \
            --title="Displays" \
            --width=240 \
            --height=250 \
            --center \
            --no-headers \
            --column="Profile" \
            "Vertical" \
	    "Horizontal" \
            "Laptop" \
            "External" \
            "Auto" \
            "Open wdisplays" \
            "Quit" 2>/dev/null || true
    )"

    case "${choice%%|*}" in
        "Vertical") "$0" vertical ;;
        "Horizontal") "$0" horizontal ;;
        "Laptop") "$0" laptop ;;
        "External") "$0" external ;;
        "Auto") "$0" auto ;;
        "Open wdisplays") "$0" wdisplays ;;
        "Quit") "$0" quit ;;
    esac
}

run_tray() {
    install -d "$STATE_DIR"
    [[ -f "$ACTIVE_FILE" ]] || printf '%s\n' "vertical" > "$ACTIVE_FILE"

    if python3 - <<'PY' >/dev/null 2>&1
import gi
gi.require_version("Gtk", "3.0")
gi.require_version("AppIndicator3", "0.1")
from gi.repository import AppIndicator3, Gtk
PY
    then
        exec python3 - "$0" <<'PY'
import subprocess
import sys

import gi
gi.require_version("Gtk", "3.0")
gi.require_version("AppIndicator3", "0.1")
from gi.repository import AppIndicator3, Gtk

script = sys.argv[1]

indicator = AppIndicator3.Indicator.new(
    "display-profiles",
    "video-display",
    AppIndicator3.IndicatorCategory.APPLICATION_STATUS,
)
indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
indicator.set_title("Display profiles")

menu = Gtk.Menu()

def add_item(label, *args, quit_after=False):
    item = Gtk.MenuItem(label=label)

    def activate(_item):
        subprocess.Popen([script, *args])
        if quit_after:
            Gtk.main_quit()

    item.connect("activate", activate)
    menu.append(item)

add_item("Vertical", "vertical")
add_item("Horizontal", "horizontal")
add_item("Laptop", "laptop")
add_item("External", "external")
add_item("Auto", "auto")
menu.append(Gtk.SeparatorMenuItem())
add_item("Open wdisplays", "wdisplays")
add_item("Quit", "quit", quit_after=True)

menu.show_all()
indicator.set_menu(menu)
Gtk.main()
PY
    fi

    exec yad --notification \
        --image="video-display" \
        --text="Display profiles" \
        --command="$0 menu" \
        --menu="Vertical!$0 vertical|Horizontal!$0 horizontal|Laptop!$0 laptop|External!$0 external|Auto!$0 auto|Open wdisplays!$0 wdisplays|Quit!$0 quit"
}

case "${1:-tray}" in
    tray) run_tray ;;
    menu) open_menu ;;
    vertical) vertical_profile ;;
    horizontal) horizontal_profile ;;
    laptop) laptop_profile ;;
    external) external_profile ;;
    auto) auto_profile ;;
    wdisplays) open_wdisplays ;;
    quit)
        pkill -u "$USER" -f "yad --notification.*Display profiles" >/dev/null 2>&1 || true
        ;;
    *)
        echo "Usage: $0 [tray|menu|vertical|laptop|external|auto|wdisplays|quit]" >&2
        exit 2
        ;;
esac
