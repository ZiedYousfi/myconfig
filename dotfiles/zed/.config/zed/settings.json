{
  "collaboration_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "opencode": {
      "favorite_config_option_values": {
        "model": [
          "github-copilot/claude-opus-4.7/medium",
          "openai/gpt-5.5/low"
        ]
      },
      "type": "registry"
    }
  },
  "tab_bar": {
    "show": false
  },
  "max_tabs": 1,
  "title_bar": {
    "show_menus": false,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": false,
    "show_onboarding_banner": true
  },
  "show_edit_predictions": false,
  "base_keymap": "VSCode",
  "terminal": {
    "scrollbar": {
      "show": "always"
    }
  },
  "buffer_line_height": "standard",
  "buffer_font_weight": 450.0,
  "ui_font_size": 18.0,
  "ui_font_weight": 450.0,
  "completion_menu_scrollbar": "auto",
  "soft_wrap": "editor_width",
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "gutter": {
    "folds": false
  },
  "scrollbar": {
    "show": "never"
  },
  "relative_line_numbers": "enabled",
  "autosave": {
    "after_delay": {
      "milliseconds": 2000
    }
  },
  "rounded_selection": false,
  "unnecessary_code_fade": 0.0,
  "hide_mouse": "never",
  "ui_font_family": "Iosevka Nerd Font",
  "buffer_font_size": 18.0,
  "buffer_font_family": "Iosevka Nerd Font Mono",
  "auto_update": false,
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "close_window",
  "agent": {
    "show_turn_stats": true,
    "dock": "left",
    "favorite_models": [],
    "model_parameters": []
  },
  "outline_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "project_panel": {
    "dock": "right"
  },
  "icon_theme": "Zed (Default)",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "vim_mode": true,
  "theme": "Black & Pink"
}
