          "function.builtin": { "color": "#ff85c8" },
          "hint": { "color": "#a78bfa" },
          "keyword": { "color": "#ff4ead" },
          "label": { "color": "#60a5fa" },
          "link_text": { "color": "#ff4ead", "font_style": "italic" },
          "link_uri": { "color": "#ff85c8" },
          "number": { "color": "#facc15" },
          "operator": { "color": "#a0aabe" },
          "predictive": { "color": "#4a4f5e", "font_style": "italic" },
          "preproc": { "color": "#a78bfa" },
          "primary": { "color": "#d0d6e0" },
          "property": { "color": "#d0d6e0" },
          "punctuation": { "color": "#a0aabe" },
          "punctuation.bracket": { "color": "#a0aabe" },
          "punctuation.delimiter": { "color": "#a0aabe" },
          "punctuation.list_marker": { "color": "#ff4ead" },
          "punctuation.special": { "color": "#ff4ead" },
          "string": { "color": "#4ade80" },
          "string.escape": { "color": "#ff85c8" },
          "string.regex": { "color": "#ff85c8" },
          "string.special": { "color": "#facc15" },
          "string.special.symbol": { "color": "#22d3ee" },
          "tag": { "color": "#ff4ead" },
          "text.literal": { "color": "#4ade80" },
          "title": { "color": "#f0f2f7", "font_weight": 700 },
          "type": { "color": "#f0f2f7" },
          "type.builtin": { "color": "#f0f2f7" },
          "variable": { "color": "#d0d6e0" },
          "variable.parameter": { "color": "#c0c8d8" },
          "variable.special": { "color": "#ff4ead" },
          "variant": { "color": "#22d3ee" }
