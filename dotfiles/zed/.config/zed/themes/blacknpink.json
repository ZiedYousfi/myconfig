{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Black & Pink",
  "author": "Black N Pink",
  "themes": [
    {
      "name": "Black & Pink",
      "appearance": "dark",
      "style": {
        "background.appearance": "opaque",
        "accents": [
          "#ff4ead",
          "#ff85c8",
          "#a78bfa",
          "#22d3ee",
          "#4ade80",
          "#facc15",
          "#60a5fa",
          "#f87171"
        ],
        "background": "#000000",
        "border": "#1a1a1a",
        "border.variant": "#1a1a1a",
        "border.focused": "#ff4ead",
        "border.selected": "#ff4ead",
        "border.transparent": "#00000000",
        "border.disabled": "#1a1a1a",
        "elevated_surface.background": "#0a0a0a",
        "surface.background": "#0a0a0a",
        "drop_target.background": "#ff4ead33",

        "element.background": "#0a0a0a",
        "element.hover": "#222222",
        "element.active": "#ff4ead1a",
        "element.selected": "#ff4ead1a",
        "element.disabled": "#1a1a1a",

        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#222222",
        "ghost_element.active": "#ff4ead1a",
        "ghost_element.selected": "#ff4ead1a",
        "ghost_element.disabled": "#1a1a1a",

        "text": "#d0d6e0",
        "text.muted": "#a0aabe",
        "text.placeholder": "#4a4f5e",
