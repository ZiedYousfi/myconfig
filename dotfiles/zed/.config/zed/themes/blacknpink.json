          {
            "cursor": "#22d3ee",
            "background": "#22d3ee",
            "selection": "#22d3ee1a"
          },
          {
            "cursor": "#a78bfa",
            "background": "#a78bfa",
            "selection": "#a78bfa1a"
          },
          {
            "cursor": "#4ade80",
            "background": "#4ade80",
            "selection": "#4ade801a"
          },
          {
            "cursor": "#facc15",
            "background": "#facc15",
            "selection": "#facc151a"
          },
          {
            "cursor": "#60a5fa",
            "background": "#60a5fa",
            "selection": "#60a5fa1a"
          },
          {
            "cursor": "#ff85c8",
            "background": "#ff85c8",
            "selection": "#ff85c81a"
          },
          {
            "cursor": "#f87171",
            "background": "#f87171",
            "selection": "#f871711a"
          }
        ],

