        "renamed.border": "#60a5fa",

        "hidden": "#4a4f5e",
        "hidden.background": "#0a0a0a",
        "hidden.border": "#1a1a1a",

        "ignored": "#4a4f5e",
        "ignored.background": "#0a0a0a",
        "ignored.border": "#1a1a1a",

        "predictive": "#4a4f5e",
        "predictive.background": "#0a0a0a",
        "predictive.border": "#4a4f5e",

        "unreachable": "#4a4f5e",
        "unreachable.background": "#0a0a0a",
        "unreachable.border": "#4a4f5e",

        "error": "#f87171",
        "error.background": "#0a0a0a",
        "error.border": "#f87171",

        "warning": "#facc15",
        "warning.background": "#0a0a0a",
        "warning.border": "#facc15",

        "info": "#60a5fa",
