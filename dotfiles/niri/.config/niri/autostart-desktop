#!/usr/bin/env bash
set -euo pipefail

desktop_names=()
desktop_files=()

add_desktop_file() {
    local file="$1"
    local base
    base="$(basename "$file")"

    for existing in "${desktop_names[@]}"; do
        [[ "$existing" == "$base" ]] && return
    done

    desktop_names+=("$base")
    desktop_files+=("$file")
}

desktop_value() {
    local key="$1"
    local file="$2"

    awk -F= -v key="$key" '
        $0 == "[Desktop Entry]" { in_entry=1; next }
        /^\[/ { in_entry=0 }
        in_entry && $1 == key {
            sub(/^[^=]*=/, "")
            print
            exit
        }
    ' "$file"
}

contains_desktop() {
    local list="$1"
    local desktop="${XDG_CURRENT_DESKTOP:-niri}"
    local session="${DESKTOP_SESSION:-niri}"
    local entry

    IFS=';' read -ra entries <<< "$list"
    for entry in "${entries[@]}"; do
        [[ -z "$entry" ]] && continue
        [[ "${entry,,}" == "${desktop,,}" || "${entry,,}" == "${session,,}" ]] && return 0
    done

    return 1
}

is_enabled() {
    local file="$1"
    local hidden autostart_enabled only_show_in not_show_in

    [[ "$(desktop_value Type "$file")" == "Application" ]] || return 1

    hidden="$(desktop_value Hidden "$file")"
    [[ "${hidden,,}" == "true" ]] && return 1

    autostart_enabled="$(desktop_value X-GNOME-Autostart-enabled "$file")"
    [[ "${autostart_enabled,,}" == "false" ]] && return 1

    only_show_in="$(desktop_value OnlyShowIn "$file")"
    [[ -n "$only_show_in" ]] && ! contains_desktop "$only_show_in" && return 1

    not_show_in="$(desktop_value NotShowIn "$file")"
    [[ -n "$not_show_in" ]] && contains_desktop "$not_show_in" && return 1

    [[ -n "$(desktop_value Exec "$file")" ]]
}

desktop_exec_to_shell() {
    local exec_line="$1"

    exec_line="${exec_line//%%/$'\001'}"
    exec_line="$(printf '%s\n' "$exec_line" | sed -E 's/[[:space:]]+%[fFuUdDnNickvm]//g; s/%[fFuUdDnNickvm]//g')"
    exec_line="${exec_line//$'\001'/%}"

    printf '%s\n' "$exec_line"
}

dir="${XDG_CONFIG_HOME:-$HOME/.config}/autostart"
if [[ -d "$dir" ]]; then
    for file in "$dir"/*.desktop; do
        [[ -f "$file" ]] || continue
        add_desktop_file "$file"
    done
fi

if [[ "${1:-}" == "--list" ]]; then
    for file in "${desktop_files[@]}"; do
        is_enabled "$file" || continue

        printf '%s\t%s\n' \
            "$(desktop_value Name "$file")" \
            "$(desktop_exec_to_shell "$(desktop_value Exec "$file")")"
    done
    exit 0
fi

for file in "${desktop_files[@]}"; do
    is_enabled "$file" || continue

    exec_line="$(desktop_exec_to_shell "$(desktop_value Exec "$file")")"
    [[ -n "$exec_line" ]] || continue

    sh -lc "$exec_line" &
done
