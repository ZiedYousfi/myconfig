#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/kanata"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/kanata"
PID_FILE="$STATE_DIR/kanata.pid"
ACTIVE_FILE="$STATE_DIR/profile"
LOG_FILE="$STATE_DIR/kanata.log"

notify() {
    notify-send "Kanata" "$1" >/dev/null 2>&1 || true
}

kill_kanata() {
    if [[ -f "$PID_FILE" ]]; then
        local pid
        pid="$(cat "$PID_FILE" 2>/dev/null || true)"
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
        fi
        rm -f "$PID_FILE"
    fi

    pkill -u "$USER" -x kanata >/dev/null 2>&1 || true
}

start_profile() {
    local profile="$1"
    local label="$2"
    local cfg="$CONFIG_DIR/$profile.kbd"

    if [[ ! -f "$cfg" ]]; then
        notify "Profile not found: $cfg"
        exit 1
    fi

    install -d "$STATE_DIR"
    kill_kanata
    kanata --cfg "$cfg" >>"$LOG_FILE" 2>&1 &
    echo "$!" > "$PID_FILE"
    echo "$profile" > "$ACTIVE_FILE"
    notify "Profile active: $label"
}

turn_off() {
    start_profile off "Off"
}

quit_kanata() {
    install -d "$STATE_DIR"
    kill_kanata
    echo "off" > "$ACTIVE_FILE"
    notify "Kanata disabled"
}

open_menu() {
    local choice
    choice="$(
        yad --list \
            --title="Kanata" \
            --width=220 \
            --height=220 \
            --center \
            --no-headers \
            --column="Profile" \
            "Home Row" \
            "Disabled" \
            "Valo" \
            "Off" \
            "Quit" 2>/dev/null || true
    )"

    case "${choice%%|*}" in
        "Home Row") "$0" profile homerow "Home Row" ;;
        "Disabled") "$0" profile disabled "Disabled" ;;
        "Valo") "$0" profile valo "Valo" ;;
        "Off") "$0" off ;;
        "Quit") "$0" quit ;;
    esac
}

run_tray() {
    install -d "$STATE_DIR"
    turn_off

    if python3 - <<'PY' >/dev/null 2>&1
import gi
gi.require_version("Gtk", "3.0")
gi.require_version("AppIndicator3", "0.1")
from gi.repository import AppIndicator3, Gtk
PY
    then
        exec python3 - "$0" <<'PY'
import subprocess
import sys

import gi
gi.require_version("Gtk", "3.0")
gi.require_version("AppIndicator3", "0.1")
from gi.repository import AppIndicator3, Gtk

script = sys.argv[1]

indicator = AppIndicator3.Indicator.new(
    "kanata-profiles",
    "input-keyboard",
    AppIndicator3.IndicatorCategory.APPLICATION_STATUS,
)
indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
indicator.set_title("Kanata profiles")

menu = Gtk.Menu()

def add_item(label, *args, quit_after=False):
    item = Gtk.MenuItem(label=label)

    def activate(_item):
        subprocess.Popen([script, *args])
        if quit_after:
            Gtk.main_quit()

    item.connect("activate", activate)
    menu.append(item)

add_item("Home Row", "profile", "homerow", "Home Row")
add_item("Disabled", "profile", "disabled", "Disabled")
add_item("Valo", "profile", "valo", "Valo")
menu.append(Gtk.SeparatorMenuItem())
add_item("Off", "off")
add_item("Quit", "quit", quit_after=True)

menu.show_all()
indicator.set_menu(menu)
Gtk.main()
PY
    fi

    exec yad --notification \
        --image="input-keyboard" \
        --text="Kanata profiles" \
        --command="$0 menu" \
        --menu="Home Row!$0 profile homerow 'Home Row'|Disabled!$0 profile disabled Disabled|Valo!$0 profile valo Valo|Off!$0 off|Quit!$0 quit"
}

case "${1:-tray}" in
    tray) run_tray ;;
    menu) open_menu ;;
    profile) start_profile "${2:?profile missing}" "${3:-$2}" ;;
    off) turn_off ;;
    quit)
        quit_kanata
        pkill -u "$USER" -f "yad --notification.*Kanata profiles" >/dev/null 2>&1 || true
        ;;
    *)
        echo "Usage: $0 [tray|menu|profile NAME [LABEL]|off|quit]" >&2
        exit 2
        ;;
esac
