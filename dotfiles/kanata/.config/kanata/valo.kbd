(defcfg
  process-unmapped-keys yes
)

(defsrc
  2        1        q        f1       3        z        s f17        f18
)

(defalias
  two (tap-hold 200 200 e q)
  one (tap-hold 200 200 . b)
  qqq (tap-hold 200 200 = g)
  f01 (tap-hold 200 200 i f)
  thr (tap-hold 200 200 v r)
  zzz (tap-hold 200 200 c n)
  scroll-up   (mwheel-up 50 120)
  scroll-down (mwheel-down 50 120)
)

(deflayer base
  @two @one @qqq @f01 @thr @zzz d @scroll-up @scroll-down
)
