(defcfg
  process-unmapped-keys yes
)

(defsrc
  z    a    s    w    c          v            f17        f18
)

(defalias
  dis-z (tap-hold 200 200 z lmet)
  dis-a (tap-hold 200 200 a lalt)
  dis-s (tap-hold 200 200 s lctl)
  dis-w (tap-hold 200 200 w lsft)
  scroll-up   (mwheel-up 50 120)
  scroll-down (mwheel-down 50 120)
)

(deflayer base
  @dis-z @dis-a @dis-s @dis-w @scroll-up @scroll-down @scroll-up @scroll-down
)
