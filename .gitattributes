# Auto detect text files and normalize line endings to LF in the repository
* text=auto

# PowerShell files should always use CRLF line endings
*.ps1 text eol=crlf

# Shell scripts should always use LF line endings
*.sh text eol=lf
*.zsh text eol=lf
dotfiles/kanata/.config/kanata/kanata-tray text eol=lf
*.kbd text eol=lf
.zshrc text eol=lf
.zshenv text eol=lf
.zprofile text eol=lf
.zlogin text eol=lf
.zlogout text eol=lf

# Explicitly declare text files
*.md text
*.yaml text
*.yml text
*.json text
*.css text
*.html text
*.txt text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
